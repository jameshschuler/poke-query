# App environment
NODE_ENV=development
LOG_LEVEL=info

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SECRET_KEY=your-supabase-secret-key

# Session cookie signing secret
COOKIE_SECRET=replace-with-a-long-random-string
CORS_ORIGIN=http://localhost:3000

# Postgres connection (used by Drizzle)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Integration tests (used by test:integration)
# Both IDs must exist in auth.users in your test project.
INTEGRATION_TEST_USER_ID=00000000-0000-4000-8000-000000000001
INTEGRATION_TEST_OTHER_USER_ID=00000000-0000-4000-8000-000000000002

# Seed data auth/trainer options
# Seeded auth users are created via Supabase Auth admin API.
SEED_OFFICIAL_EMAIL=official@seed.pokequery.local
SEED_COMMUNITY_ACCOUNT_COUNT=4
SEED_COMMUNITY_EMAIL_PREFIX=community
SEED_EMAIL_DOMAIN=seed.pokequery.local
SEED_TRAINER_USER_IDS=

# Production curated search seed owner (used by db:seed:search:prod)
PROD_SEED_OFFICIAL_EMAIL=official@seed.pokequery.local
